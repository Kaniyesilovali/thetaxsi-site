{
  "name": "taxsi-static",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs && npx @tailwindcss/cli -i ./tailwind.css -o ./dist/assets/main.css --minify",
    "serve": "python3 -m http.server 8080 -d dist",
    "dev": "npm run build && npm run serve"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "tailwindcss": "^4.1.0"
  }
}
